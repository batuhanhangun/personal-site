# ┌─────────────────────────────────────────────────────────────────────────┐
# │  Environment Variables — copy to .env and fill in real values           │
# │  .env is git-ignored. Never commit actual secrets.                      │
# └─────────────────────────────────────────────────────────────────────────┘

# ── Cloudflare Worker: citation-metrics ────────────────────────────────────────
# Set these via `wrangler secret put <KEY>` in workers/citation-metrics/
# They live only in the Cloudflare dashboard — never in this file.
#
# SERPAPI_KEY=          # SerpAPI key for Google Scholar scraping
# SCOPUS_API_KEY=       # Elsevier API key for Scopus metrics
# SCOPUS_AUTHOR_ID=     # Scopus numeric author ID (e.g. 57200000000)


# ── Cloudflare Worker: contact form (Astro API route) ─────────────────────────
# TURNSTILE_SECRET is set as a Cloudflare Pages secret (dashboard → Settings →
# Environment variables → type: Secret). NOT stored here.
#
# TURNSTILE_SECRET=     # Cloudflare Turnstile secret key (server-side only)


# ── Frontend build-time variables (safe to commit if PUBLIC_) ─────────────────

# Turnstile site key — public, fine to expose in HTML/JS.
# For local dev use the always-pass test key: 1x00000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# URL of the deployed citation-metrics Worker.
# Production: https://citation-metrics.<account>.workers.dev
# Local dev:  http://localhost:8787  (run `npm run dev` in workers/citation-metrics/)
PUBLIC_METRICS_API_URL=
