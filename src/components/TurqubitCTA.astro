---
import Section from './Section.astro';
---

<Section id="turqubit">
  <div class="turqubit-card">

    <!-- Background glow layers -->
    <div class="tq-glow tq-glow-1" aria-hidden="true"></div>
    <div class="tq-glow tq-glow-2" aria-hidden="true"></div>

    <!-- Icon -->
    <div class="tq-icon" aria-hidden="true">
      <svg viewBox="0 0 48 48" fill="none" width="42" height="42">
        <!-- Quantum circuit / node cluster -->
        <circle cx="24" cy="24" r="4" fill="#00d4ff" opacity="0.9"/>
        <circle cx="8"  cy="16" r="2.5" fill="#a855f7" opacity="0.8"/>
        <circle cx="40" cy="16" r="2.5" fill="#a855f7" opacity="0.8"/>
        <circle cx="8"  cy="32" r="2.5" fill="#a855f7" opacity="0.8"/>
        <circle cx="40" cy="32" r="2.5" fill="#a855f7" opacity="0.8"/>
        <line x1="10" y1="16" x2="20" y2="22" stroke="#00d4ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="38" y1="16" x2="28" y2="22" stroke="#00d4ff" stroke-width="1.2" opacity="0.5"/>
        <line x1="10" y1="32" x2="20" y2="26" stroke="#a855f7" stroke-width="1.2" opacity="0.5"/>
        <line x1="38" y1="32" x2="28" y2="26" stroke="#a855f7" stroke-width="1.2" opacity="0.5"/>
        <!-- Orbit ring -->
        <ellipse cx="24" cy="24" rx="20" ry="7" fill="none"
          stroke="#00d4ff" stroke-width="1" opacity="0.25"
          transform="rotate(-30 24 24)"/>
      </svg>
    </div>

    <!-- Copy -->
    <div class="tq-copy">
      <p class="tq-label">Consulting & Training</p>
      <h2 class="tq-heading">Need HPC, AI, or Quantum Computing expertise?</h2>
      <p class="tq-body">
        Turqubit provides specialised consulting, hands-on training, and research
        collaboration in high-performance computing, applied machine learning, and
        quantum algorithm development — from proof-of-concept to production.
      </p>
    </div>

    <!-- CTA button -->
    <div class="tq-action">
      <a
        href="https://turqubit.com"
        target="_blank"
        rel="noopener noreferrer"
        class="tq-btn"
        aria-label="Visit Turqubit — HPC, AI, and Quantum Computing consulting"
      >
        <span>Visit Turqubit</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round"
             stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </div>
</Section>

<style>
  /* ── Wrapper card with gradient border ──────────────────────────────── */
  .turqubit-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    padding: 3rem 2rem;
    border-radius: 1rem;
    overflow: hidden;

    /* gradient border via background-clip trick */
    background:
      linear-gradient(rgba(10, 10, 15, 0.92), rgba(10, 10, 15, 0.92)) padding-box,
      linear-gradient(135deg, #00d4ff 0%, #a855f7 50%, #00d4ff 100%) border-box;
    border: 1px solid transparent;
  }

  @media (min-width: 768px) {
    .turqubit-card {
      flex-direction: row;
      text-align: left;
      align-items: center;
      padding: 3rem 3.5rem;
      gap: 2.5rem;
    }
  }

  /* ── Background glow layers ─────────────────────────────────────────── */
  .tq-glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(64px);
    opacity: 0.08;
  }
  .tq-glow-1 {
    width: 320px; height: 320px;
    background: #00d4ff;
    top: -80px; left: -60px;
  }
  .tq-glow-2 {
    width: 280px; height: 280px;
    background: #a855f7;
    bottom: -60px; right: -40px;
  }

  /* ── Icon ───────────────────────────────────────────────────────────── */
  .tq-icon {
    flex-shrink: 0;
    z-index: 1;
    opacity: 0.9;
  }

  /* ── Copy block ─────────────────────────────────────────────────────── */
  .tq-copy {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    z-index: 1;
    min-width: 0;
  }

  .tq-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #a855f7;
    margin: 0;
  }

  .tq-heading {
    font-size: clamp(1.1rem, 2.5vw, 1.45rem);
    font-weight: 700;
    line-height: 1.3;
    color: #f0f0f0;
    margin: 0;
  }

  .tq-body {
    font-size: 0.88rem;
    color: #a0a0b0;
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }

  /* ── CTA button ─────────────────────────────────────────────────────── */
  .tq-action {
    flex-shrink: 0;
    z-index: 1;
  }

  .tq-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.6rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #0a0a0f;
    background: linear-gradient(135deg, #00d4ff 0%, #a855f7 100%);
    transition: opacity 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }
  .tq-btn:hover {
    opacity: 0.88;
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(0, 212, 255, 0.25);
  }
  .tq-btn svg {
    transition: transform 0.2s ease;
  }
  .tq-btn:hover svg {
    transform: translateX(3px);
  }
</style>
