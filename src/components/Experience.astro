---
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

interface SubRole {
  orgs: string;
  period: string;
  type: 'Hybrid' | 'Remote' | 'On-site';
  taught: string;
}

interface Exp {
  role: string;
  org: string;
  location: string;
  flag: string;
  type: 'Hybrid' | 'Remote' | 'On-site';
  period: string;
  current?: boolean;
  bullets: string[];
  subRoles?: SubRole[];
}

const experiences: Exp[] = [
  {
    role: 'Researcher',
    org: 'Yıldız Technical University',
    location: 'Istanbul, Turkey',
    flag: '🇹🇷',
    type: 'Hybrid',
    period: '2021 — Present',
    current: true,
    bullets: [
      'Quantum Machine Learning research: hybrid classical–quantum models (ANN + QNN) for renewable energy and smart grid applications',
      '19 peer-reviewed papers (4 journal + 15 conference), 197 citations',
      'Presented at 4 international IEEE conferences across 3 countries (USA, Greece, UK)',
      'GPU-based parallel computing on DOE supercomputing resources — NERSC Perlmutter (Cray EX)',
    ],
  },
  {
    role: 'Software Engineer & Researcher',
    org: 'PIXSelect Teknoloji A.Ş.',
    location: 'Istanbul, Turkey',
    flag: '🇹🇷',
    type: 'Hybrid',
    period: '2023 — 2024',
    bullets: [
      'Developed web-based data annotation and training tool for industrial vision systems',
      'Implemented computer vision, backend, and AWS modules using Python and Bash on Linux',
      'Led codebase refactoring to reduce technical debt',
    ],
  },
  {
    role: 'Visiting Researcher',
    org: 'BTU Cottbus-Senftenberg',
    location: 'Cottbus, Germany',
    flag: '🇩🇪',
    type: 'On-site',
    period: '2023',
    bullets: [
      'Contributed to an industry-targeted digital twin project with international research partners',
    ],
  },
  {
    role: 'University Lecturer',
    org: 'Multiple Universities',
    location: 'Turkey',
    flag: '🇹🇷',
    type: 'Hybrid',
    period: '2022 — 2026',
    subRoles: [
      {
        orgs: 'Ankara Bilim University',
        period: 'Sep 2025 — Jan 2026',
        type: 'Remote',
        taught: 'History of video games, genres, design tools, and practical applications with C++',
      },
      {
        orgs: 'İstanbul Aydın University',
        period: 'Jan 2025 — Jun 2025',
        type: 'On-site',
        taught: 'Digital image processing and practical applications with Python',
      },
      {
        orgs: 'Nişantaşı Univ. · Ankara Bilim Univ. · İstinye Univ.',
        period: '2022 — 2024',
        type: 'Hybrid',
        taught: 'Parallel computing (C, C++, MATLAB) and AI/ML fundamentals (Python)',
      },
    ],
    bullets: [
      'Adopted project-based and presentation-based learning approach across all institutions',
    ],
  },
  {
    role: 'Software Engineer',
    org: 'Polyga Inc.',
    location: 'Vancouver, Canada',
    flag: '🇨🇦',
    type: 'Remote',
    period: '2021 — 2022',
    bullets: [
      'SDK development for 3D scanning devices using C++ (11, 14)',
      'Camera calibration testing using C++ and MATLAB',
    ],
  },
  {
    role: 'Research & Teaching Assistant',
    org: 'Nişantaşı University',
    location: 'Istanbul, Turkey',
    flag: '🇹🇷',
    type: 'On-site',
    period: '2016 — 2021',
    bullets: [
      'Course support, conference organisation, and journal editorial activities',
    ],
  },
];

const typeColor: Record<Exp['type'], string> = {
  Hybrid:    'type-hybrid',
  Remote:    'type-remote',
  'On-site': 'type-onsite',
};
---

<Section id="experience">
  <SectionHeading title="Experience" />

  <div class="exp-list" role="list">
    {experiences.map(exp => (
      <article class="exp-card" role="listitem">

        <!-- Left accent -->
        <div class:list={['exp-accent', exp.current && 'exp-accent--current']} aria-hidden="true" />

        <!-- Content -->
        <div class="exp-body">

          <!-- Header -->
          <header class="exp-header">
            <div class="exp-header-main">
              <div>
                <h3 class="exp-role">{exp.role}</h3>
                <p class="exp-org">
                  {exp.org}
                  <span class="exp-location">· {exp.location}</span>
                </p>
              </div>
              <div class="exp-meta-right">
                {exp.current && (
                  <span class="current-badge" aria-label="Current position">
                    <span class="current-dot" aria-hidden="true" />
                    Current
                  </span>
                )}
                {!exp.subRoles && (
                  <span class:list={['type-pill', typeColor[exp.type]]}>
                    {exp.type}
                  </span>
                )}
                <span class="exp-period">{exp.period}</span>
              </div>
            </div>
          </header>

          <!-- Sub-roles -->
          {exp.subRoles && (
            <ul class="sub-roles" aria-label={`Positions at ${exp.org}`}>
              {exp.subRoles.map(sr => (
                <li class="sub-role">
                  <div class="sub-role-header">
                    <span class="sub-role-orgs">{sr.orgs}</span>
                    <div class="sub-role-meta">
                      <span class:list={['type-pill', typeColor[sr.type]]}>{sr.type}</span>
                      <span class="sub-role-period">{sr.period}</span>
                    </div>
                  </div>
                  <p class="sub-role-taught">
                    <span class="sub-role-label">Taught: </span>{sr.taught}
                  </p>
                </li>
              ))}
            </ul>
          )}

          <!-- Bullets -->
          <ul class="exp-bullets" aria-label={`Responsibilities at ${exp.org}`}>
            {exp.bullets.map(b => (
              <li class="exp-bullet">{b}</li>
            ))}
          </ul>

        </div>
      </article>
    ))}
  </div>
</Section>

<style>
  .exp-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Card ─────────────────────────────────────────────────────────────── */
  .exp-card {
    display: flex;
    background: #ffffff;
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .exp-card:hover {
    border-color: rgba(13, 148, 136, 0.2);
    box-shadow: 0 4px 20px rgba(28, 25, 23, 0.06);
  }

  /* Left accent bar */
  .exp-accent {
    width: 3px;
    flex-shrink: 0;
    background: rgba(28, 25, 23, 0.08);
    border-radius: 0;
  }
  .exp-accent--current {
    background: #0d9488;
  }

  .exp-body {
    flex: 1;
    padding: 1.35rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  /* ── Header ───────────────────────────────────────────────────────────── */
  .exp-header-main {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .exp-role {
    font-size: 1rem;
    font-weight: 600;
    color: #1c1917;
    line-height: 1.25;
    margin: 0 0 0.2rem;
    font-family: 'DM Sans', system-ui, sans-serif;
  }

  .exp-org {
    font-size: 0.84rem;
    color: #57534e;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    flex-wrap: wrap;
  }

  .exp-location {
    color: #a8a29e;
    font-size: 0.78rem;
  }

  .exp-meta-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .exp-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: #a8a29e;
    white-space: nowrap;
  }

  /* ── Badges ───────────────────────────────────────────────────────────── */
  .current-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.12rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.65rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #0d9488;
    background: rgba(13, 148, 136, 0.08);
    border: 1px solid rgba(13, 148, 136, 0.2);
  }

  @keyframes dotPulse {
    0%, 100% { transform: scale(1);   opacity: 0.8; }
    50%       { transform: scale(1.6); opacity: 0;   }
  }

  .current-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #0d9488;
    animation: dotPulse 1.8s ease-in-out infinite;
    flex-shrink: 0;
  }

  .type-pill {
    font-size: 0.63rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.12rem 0.45rem;
    border-radius: 9999px;
    border: 1px solid;
  }
  .type-hybrid  { color: #f97316; background: rgba(249,115,22,0.06);  border-color: rgba(249,115,22,0.2);  }
  .type-remote  { color: #0d9488; background: rgba(13,148,136,0.06);  border-color: rgba(13,148,136,0.2);  }
  .type-onsite  { color: #a8a29e; background: rgba(28,25,23,0.03);    border-color: rgba(28,25,23,0.1);    }

  /* ── Sub-roles ────────────────────────────────────────────────────────── */
  .sub-roles {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .sub-role {
    padding: 0.55rem 0.75rem;
    border-radius: 0.45rem;
    background: #ede9e4;
    border: 1px solid var(--border-subtle);
  }

  .sub-role-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
  }

  .sub-role-orgs {
    font-size: 0.84rem;
    font-weight: 600;
    color: #1c1917;
    line-height: 1.35;
  }

  .sub-role-meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-shrink: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .sub-role-period {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: #a8a29e;
    white-space: nowrap;
  }

  .sub-role-taught {
    font-size: 0.8rem;
    color: #57534e;
    line-height: 1.55;
    margin: 0;
  }

  .sub-role-label {
    color: #a8a29e;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-right: 0.2rem;
  }

  /* ── Bullets ──────────────────────────────────────────────────────────── */
  .exp-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .exp-bullet {
    position: relative;
    padding-left: 1rem;
    font-size: 0.88rem;
    color: #57534e;
    line-height: 1.65;
  }

  .exp-bullet::before {
    content: '–';
    position: absolute;
    left: 0;
    color: #a8a29e;
    font-size: 0.8rem;
  }
</style>
