---
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

type PubType = 'journal' | 'conference' | 'preprint';

interface Publication {
  type:     PubType;
  title:    string;
  authors:  string;
  venue:    string;
  year:     number;
  doi?:     string;
  arxivId?: string;
}

const publications: Publication[] = [
  {
    type:    'journal',
    title:   'QLID-Net: A Hybrid Quantum-Classical Neural Network for Robust and Data-Efficient Smart Grid Load Identification',
    authors: 'B. Hangun, O. Altun, O. Eyecioglu',
    venue:   'IEEE Access, vol. 14, pp. 32118–32133',
    year:    2026,
    doi:     '10.1109/ACCESS.2026.3668295',
  },
  {
    type:    'conference',
    title:   'A Hybrid Classical-Quantum Model for QSAR-Based Biodegradability Prediction',
    authors: 'B. Hangun, O. Altun, O. Eyecioglu',
    venue:   '2025 IEEE HPEC, Wakefield, MA, USA',
    year:    2025,
    doi:     '10.1109/HPEC67600.2025.11196555',
  },
  {
    type:    'journal',
    title:   'An OpenMP-based parallel implementation of image enhancement technique for dark images',
    authors: 'Hangun, B., & Bayar, S.',
    venue:   'Signal, Image and Video Processing',
    year:    2024,
    doi:     '10.1007/s11760-024-03058-8',
  },
  {
    type:    'conference',
    title:   'Comparative Analysis of QNN Architectures for Wind Power Prediction: Feature Maps and Ansatz Configurations',
    authors: 'Hangun, B., Altun, O., & Eyecioglu, O.',
    venue:   '2025 IEEE ISVLSI',
    year:    2025,
    doi:     '10.1109/ISVLSI65124.2025.11130210',
  },
];

function highlightAuthor(authors: string): string {
  return authors
    .replace(/B\.\s*Hangun/g,  '<strong class="pub-me">B.&nbsp;Hangun</strong>')
    .replace(/Hangun,\s*B\./g, '<strong class="pub-me">Hangun,&nbsp;B.</strong>');
}

const typeLabel: Record<PubType, string> = {
  journal:    'Journal',
  conference: 'Conference',
  preprint:   'Preprint',
};

const scholarUrl = 'https://scholar.google.com/citations?hl=en&user=kW1pVNEAAAAJ';
---

<Section id="publications">
  <SectionHeading
    title="Publications"
    subtitle="Selected from 19 peer-reviewed publications — 4 journal articles + 15 conference papers."
  />

  <!-- ── Publication cards grid ──────────────────────────────────────── -->
  <div class="pub-grid">
    {publications.map(pub => {
      const linkHref = pub.doi
        ? `https://doi.org/${pub.doi}`
        : pub.arxivId
        ? `https://arxiv.org/abs/${pub.arxivId}`
        : null;

      const linkLabel = pub.doi
        ? `DOI: ${pub.doi}`
        : pub.arxivId
        ? `arXiv: ${pub.arxivId}`
        : null;

      return (
        <article class:list={['pub-card', `pub-${pub.type}`]}>

          <div class="pub-top">
            <span class:list={['pub-badge', `badge-${pub.type}`]}>
              {typeLabel[pub.type]}
            </span>
            <span class="pub-year">{pub.year}</span>
          </div>

          <h3 class="pub-title">{pub.title}</h3>

          <p class="pub-authors" set:html={highlightAuthor(pub.authors)} />

          <p class="pub-venue">{pub.venue}</p>

          {linkHref && (
            <a
              href={linkHref}
              target="_blank"
              rel="noopener noreferrer"
              class="pub-link"
              aria-label={`Open ${linkLabel}`}
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round"
                   stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              {linkLabel}
            </a>
          )}

        </article>
      );
    })}
  </div>

  <!-- ── Google Scholar CTA ──────────────────────────────────────────── -->
  <div class="scholar-wrap">
    <a
      href={scholarUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="scholar-cta"
      aria-label="View all publications on Google Scholar"
    >
      <div class="scholar-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/>
        </svg>
      </div>

      <div class="scholar-text">
        <span class="scholar-cta-title">View All Publications on Google Scholar</span>
        <span class="scholar-cta-stats">
          <span class="scholar-stat">
            <span class="scholar-stat-value">19</span> papers
          </span>
          <span class="scholar-divider" aria-hidden="true">·</span>
          <span class="scholar-stat">
            <span class="scholar-stat-value">197</span> citations
          </span>
          <span class="scholar-divider" aria-hidden="true">·</span>
          <span class="scholar-stat">
            h-index <span class="scholar-stat-value">8</span>
          </span>
        </span>
      </div>

      <svg class="scholar-arrow" width="17" height="17" viewBox="0 0 24 24" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round"
           stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</Section>

<style>
  /* ── Grid ──────────────────────────────────────────────────────────── */
  .pub-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .pub-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.125rem;
    }
  }

  /* ── Card base ─────────────────────────────────────────────────────── */
  .pub-card {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: 1.35rem 1.4rem 1.25rem;
    border-radius: 0.75rem;
    background: var(--c-card);
    border: 1px solid var(--border-subtle);
    border-top-width: 2px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    justify-content: space-between;
  }
  .pub-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px var(--c-shadow-card);
  }

  .pub-journal    { border-top-color: var(--c-teal); }
  .pub-journal:hover  { border-color: var(--c-border-teal); border-top-color: var(--c-teal); }
  .pub-conference { border-top-color: var(--c-sage); }
  .pub-conference:hover { border-color: var(--c-sage-border); border-top-color: var(--c-sage); }
  .pub-preprint   { border-top-color: #f59e0b; }
  .pub-preprint:hover { border-color: rgba(245, 158, 11, 0.25); border-top-color: #f59e0b; }

  /* ── Top row ───────────────────────────────────────────────────────── */
  .pub-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .pub-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid;
  }
  .badge-journal {
    color: var(--c-teal-text);
    background: var(--c-teal-bg);
    border-color: var(--c-border-teal);
  }
  .badge-conference {
    color: var(--c-sage-text);
    background: var(--c-sage-bg);
    border-color: var(--c-sage-border);
  }
  .badge-preprint {
    color: #f59e0b;
    background: rgba(245, 158, 11, 0.07);
    border-color: rgba(245, 158, 11, 0.22);
  }

  .pub-year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.73rem;
    color: var(--c-muted);
    letter-spacing: 0.05em;
  }

  /* ── Title ─────────────────────────────────────────────────────────── */
  .pub-title {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--c-head);
    line-height: 1.45;
    margin: 0;
    flex: 1;
  }

  /* ── Authors ───────────────────────────────────────────────────────── */
  .pub-authors {
    font-size: 0.8rem;
    color: var(--c-muted);
    line-height: 1.5;
    margin: 0;
  }

  :global(.pub-me) {
    color: var(--c-head);
    font-weight: 600;
  }

  /* ── Venue ─────────────────────────────────────────────────────────── */
  .pub-venue {
    font-size: 0.77rem;
    color: var(--c-muted);
    font-style: italic;
    margin: 0;
    line-height: 1.4;
  }

  /* ── DOI / arXiv link ──────────────────────────────────────────────── */
  .pub-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.15rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: var(--c-muted);
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
    word-break: break-all;
  }
  .pub-link:hover { color: var(--c-teal); }
  .pub-link svg   { flex-shrink: 0; }

  /* ── Google Scholar CTA ────────────────────────────────────────────── */
  .scholar-wrap {
    display: flex;
    justify-content: center;
  }

  .scholar-cta {
    display: flex;
    align-items: center;
    gap: 1.125rem;
    width: 100%;
    max-width: 600px;
    padding: 1rem 1.4rem;
    border-radius: 0.75rem;
    background: var(--c-card);
    border: 1px solid var(--border-subtle);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }
  .scholar-cta:hover {
    border-color: var(--c-border-teal-h);
    box-shadow: 0 4px 20px var(--c-shadow-teal);
  }

  .scholar-icon {
    color: var(--c-teal);
    opacity: 0.8;
    flex-shrink: 0;
  }

  .scholar-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .scholar-cta-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-head);
  }

  .scholar-cta-stats {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.75rem;
    color: var(--c-muted);
  }

  .scholar-stat-value {
    font-family: 'JetBrains Mono', monospace;
    color: var(--c-teal);
    font-size: 0.8rem;
    font-weight: 500;
  }

  .scholar-divider {
    color: var(--c-faint);
    user-select: none;
  }

  .scholar-arrow {
    color: var(--c-muted);
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }
  .scholar-cta:hover .scholar-arrow {
    color: var(--c-teal);
    transform: translateX(3px);
  }
</style>
