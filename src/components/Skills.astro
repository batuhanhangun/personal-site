---
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

type Accent = 'cyan' | 'purple' | 'neutral';

interface SkillCat {
  name: string;
  skills: string[];
  accent: Accent;
  featured?: boolean;
  /** Inner SVG markup (paths / shapes) for the 24×24 icon */
  icon: string;
}

const categories: SkillCat[] = [
  /* ── Featured (differentiators) ───────────────────────────────── */
  {
    name:     'Quantum Computing',
    accent:   'cyan',
    featured: true,
    skills:   ['Qiskit', 'PennyLane'],
    /* Atom — three orbital ellipses + nucleus */
    icon: `
      <circle cx="12" cy="12" r="1.8" fill="currentColor"/>
      <ellipse cx="12" cy="12" rx="10" ry="3.8"
        fill="none" stroke="currentColor" stroke-width="1.4"/>
      <ellipse cx="12" cy="12" rx="10" ry="3.8"
        fill="none" stroke="currentColor" stroke-width="1.4"
        transform="rotate(60 12 12)"/>
      <ellipse cx="12" cy="12" rx="10" ry="3.8"
        fill="none" stroke="currentColor" stroke-width="1.4"
        transform="rotate(-60 12 12)"/>
    `,
  },
  {
    name:     'HPC & Parallel Computing',
    accent:   'purple',
    featured: true,
    skills:   ['OpenMP', 'CUDA', 'GPU Computing', 'NERSC Perlmutter'],
    /* CPU chip with pins */
    icon: `
      <rect x="5" y="5" width="14" height="14" rx="1.5"
        fill="none" stroke="currentColor" stroke-width="1.4"/>
      <rect x="9" y="9" width="6" height="6"
        fill="none" stroke="currentColor" stroke-width="1.4"/>
      <line x1="9"  y1="2"  x2="9"  y2="5"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="15" y1="2"  x2="15" y2="5"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="9"  y1="19" x2="9"  y2="22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="15" y1="19" x2="15" y2="22" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="2"  y1="9"  x2="5"  y2="9"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="2"  y1="15" x2="5"  y2="15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="19" y1="9"  x2="22" y2="9"  stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="19" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    `,
  },

  /* ── Standard ──────────────────────────────────────────────────── */
  {
    name:   'Programming Languages',
    accent: 'neutral',
    skills: ['Python', 'C++', 'C', 'MATLAB', 'Bash', 'PowerShell'],
    /* </> brackets */
    icon: `
      <polyline points="16 18 22 12 16 6"
        fill="none" stroke="currentColor" stroke-width="1.6"
        stroke-linecap="round" stroke-linejoin="round"/>
      <polyline points="8 6 2 12 8 18"
        fill="none" stroke="currentColor" stroke-width="1.6"
        stroke-linecap="round" stroke-linejoin="round"/>
    `,
  },
  {
    name:   'ML / Data Science',
    accent: 'neutral',
    skills: ['NumPy', 'Scikit-learn', 'Pandas', 'Matplotlib', 'OpenCV', 'Albumentations'],
    /* Bar-chart / analytics */
    icon: `
      <line x1="18" y1="20" x2="18" y2="9"
        stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="12" y1="20" x2="12" y2="4"
        stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="6"  y1="20" x2="6"  y2="14"
        stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      <line x1="2"  y1="20" x2="22" y2="20"
        stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    `,
  },
  {
    name:   'Other Tools',
    accent: 'neutral',
    skills: ['Flask', 'Boto3 (AWS)', 'LaTeX', 'Sphinx', 'Simulink'],
    /* Settings gear */
    icon: `
      <circle cx="12" cy="12" r="3"
        fill="none" stroke="currentColor" stroke-width="1.5"/>
      <path fill="none" stroke="currentColor" stroke-width="1.5"
        stroke-linecap="round"
        d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06
           a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09
           A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06
           a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15
           a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9
           a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06
           A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09
           a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06
           a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9
           a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09
           a1.65 1.65 0 0 0-1.51 1z"/>
    `,
  },
];

const featured  = categories.filter(c =>  c.featured);
const standard  = categories.filter(c => !c.featured);
---

<Section id="skills">
  <SectionHeading label="04 —" title="Skills" />

  <!-- ── Featured row ─────────────────────────────────────────────── -->
  <div class="featured-row" role="list" aria-label="Core competencies">
    {featured.map(cat => (
      <div
        class:list={['skill-card', `skill-card--${cat.accent}`]}
        role="listitem"
      >
        <header class="skill-cat-header">
          <div class="skill-cat-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="20" height="20" set:html={cat.icon} />
          </div>
          <h3 class="skill-cat-name">{cat.name}</h3>
          <span class="skill-count" aria-label={`${cat.skills.length} skills`}>
            {cat.skills.length}
          </span>
        </header>

        <div class="skill-pills" role="list" aria-label={`${cat.name} skills`}>
          {cat.skills.map(s => (
            <span
              class:list={['skill-pill', `pill--${cat.accent}`]}
              role="listitem"
            >
              {s}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- ── Standard row ─────────────────────────────────────────────── -->
  <div class="standard-row" role="list" aria-label="Additional skills">
    {standard.map(cat => (
      <div class="skill-card" role="listitem">
        <header class="skill-cat-header">
          <div class="skill-cat-icon skill-cat-icon--muted" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" set:html={cat.icon} />
          </div>
          <h3 class="skill-cat-name skill-cat-name--muted">{cat.name}</h3>
          <span class="skill-count" aria-label={`${cat.skills.length} skills`}>
            {cat.skills.length}
          </span>
        </header>

        <div class="skill-pills" role="list" aria-label={`${cat.name} skills`}>
          {cat.skills.map(s => (
            <span class="skill-pill pill--neutral" role="listitem">{s}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</Section>

<style>
  /* ── Grid rows ────────────────────────────────────────────────────── */
  .featured-row,
  .standard-row {
    display: grid;
    gap: 1.125rem;
  }

  .featured-row {
    grid-template-columns: 1fr;
    margin-bottom: 1.125rem;
  }

  .standard-row {
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .featured-row  { grid-template-columns: repeat(2, 1fr); }
    .standard-row  { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .standard-row { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Base card ────────────────────────────────────────────────────── */
  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.35rem 1.4rem;
    border-radius: 0.75rem;
    background: rgba(19, 19, 32, 0.65);
    border: 1px solid var(--border-subtle);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  /* Featured: cyan */
  .skill-card--cyan {
    border-color: rgba(0, 212, 255, 0.2);
    background:
      radial-gradient(ellipse at 10% 10%, rgba(0, 212, 255, 0.05) 0%, transparent 60%),
      rgba(19, 19, 32, 0.65);
  }
  .skill-card--cyan:hover {
    border-color: rgba(0, 212, 255, 0.38);
    box-shadow: 0 6px 32px rgba(0, 212, 255, 0.08);
  }

  /* Featured: purple */
  .skill-card--purple {
    border-color: rgba(168, 85, 247, 0.2);
    background:
      radial-gradient(ellipse at 10% 10%, rgba(168, 85, 247, 0.05) 0%, transparent 60%),
      rgba(19, 19, 32, 0.65);
  }
  .skill-card--purple:hover {
    border-color: rgba(168, 85, 247, 0.38);
    box-shadow: 0 6px 32px rgba(168, 85, 247, 0.08);
  }

  /* Standard: neutral hover */
  .skill-card:not(.skill-card--cyan):not(.skill-card--purple):hover {
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  /* ── Card header ──────────────────────────────────────────────────── */
  .skill-cat-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Icon wrapper */
  .skill-cat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.5rem;
    flex-shrink: 0;
  }

  /* Colored icons for featured */
  .skill-card--cyan   .skill-cat-icon { color: #00d4ff; background: rgba(0, 212, 255, 0.1);  }
  .skill-card--purple .skill-cat-icon { color: #a855f7; background: rgba(168, 85, 247, 0.1); }

  /* Muted icon for standard */
  .skill-cat-icon--muted {
    color: #52526a;
    background: rgba(255, 255, 255, 0.04);
  }

  /* Category name */
  .skill-cat-name {
    flex: 1;
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
  }

  .skill-card--cyan   .skill-cat-name { color: #00d4ff; }
  .skill-card--purple .skill-cat-name { color: #a855f7; }
  .skill-cat-name--muted              { color: #a0a0b0; font-weight: 500; }

  /* Skill count bubble */
  .skill-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: #52526a;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 9999px;
    padding: 0.1rem 0.45rem;
    flex-shrink: 0;
  }

  /* ── Skill pills ──────────────────────────────────────────────────── */
  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.22rem 0.7rem;
    font-size: 0.74rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.03em;
    border-radius: 9999px;
    border: 1px solid;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }
  .skill-pill:hover { opacity: 0.8; }

  .pill--cyan {
    color: #00d4ff;
    background: rgba(0, 212, 255, 0.07);
    border-color: rgba(0, 212, 255, 0.2);
  }
  .pill--purple {
    color: #a855f7;
    background: rgba(168, 85, 247, 0.07);
    border-color: rgba(168, 85, 247, 0.2);
  }
  .pill--neutral {
    color: #a0a0b0;
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.09);
  }
</style>
