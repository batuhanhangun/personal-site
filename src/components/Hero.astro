---
import { Image } from 'astro:assets';
import photo    from '../assets/photo.jpg';

/**
 * Hardcoded fallback values — shown immediately (no layout shift).
 * The client-side script below overwrites them with live data from
 * the citation-metrics Worker once the page loads.
 */
const fallback = {
  scholarCitations: '197',
  hIndex:           '8',
  publications:     '19',
};

const socials = [
  {
    href:  'https://github.com/batuhanhangun',
    label: 'GitHub',
    icon:  `<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482
             0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463
             -.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832
             .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683
             -.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004
             1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647
             .64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852
             0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12
             c0-5.523-4.477-10-10-10z"/>`,
  },
  {
    href:  'https://linkedin.com/in/bhangun',
    label: 'LinkedIn',
    icon:  `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136
             1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85
             3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065
             2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771
             C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227
             24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    href:  'https://scholar.google.com/citations?hl=en&user=kW1pVNEAAAAJ',
    label: 'Google Scholar',
    icon:  `<path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10
             a8 8 0 0 1 7.162 3.44L24 9.5z"/>`,
  },
];

const metricsApiUrl = import.meta.env.PUBLIC_METRICS_API_URL ?? '';
---

<section class="min-h-[92vh] flex items-center border-b border-[var(--border-subtle)]">

  <!-- ── Main content grid ───────────────────────────────────────────────── -->
  <div class="max-w-6xl mx-auto px-6 py-24 w-full">
    <div class="grid lg:grid-cols-[300px_1fr] gap-10 xl:gap-16 items-center">

      <!-- ── Left: photo ──────────────────────────────────────────────── -->
      <div
        class="order-1 flex items-center justify-center lg:justify-start"
        style="animation: fadeIn 0.7s ease 0.2s both"
      >
        <div class="hero-photo-wrap">
          <Image
            src={photo}
            alt="Batuhan Hangün"
            width={280}
            height={280}
            quality={90}
            class="hero-photo"
            loading="eager"
          />
        </div>
      </div>

      <!-- ── Right: text ───────────────────────────────────────────────── -->
      <div class="order-2">
        <!-- Eyebrow -->
        <p
          class="font-mono text-cyan text-xs tracking-[0.2em] uppercase mb-6"
          style="animation: fadeIn 0.6s ease 0.1s both"
        >
          PhD Candidate · Quantum ML · HPC &amp; AI
        </p>

        <!-- Name -->
        <h1
          class="font-serif text-5xl md:text-6xl xl:text-[4.25rem] text-heading leading-[1.08] mb-4"
          style="animation: fadeInUp 0.65s ease 0.2s both"
        >
          Batuhan<br />Hangün
        </h1>

        <!-- Tagline -->
        <p
          class="text-lg md:text-xl font-medium mb-1"
          style="color:#0d9488; animation: fadeInUp 0.65s ease 0.3s both"
        >
          Quantum Machine Learning Researcher
        </p>
        <p
          class="text-dim text-sm md:text-base mb-8 font-mono"
          style="animation: fadeInUp 0.65s ease 0.37s both"
        >
          HPC &amp; AI Engineer · PhD Candidate at Yıldız Technical University
        </p>

        <!-- ── Stats row ─────────────────────────────────────────────── -->
        <div
          class="grid grid-cols-3 gap-2.5 mb-2 max-w-sm"
          style="animation: fadeInUp 0.65s ease 0.45s both"
          id="stats-grid"
        >
          <div class="stat-card" data-metric-card="scholar-citations">
            <span class="stat-value" id="stat-scholar-citations">
              {fallback.scholarCitations}
            </span>
            <span class="stat-label">Citations</span>
          </div>

          <div class="stat-card" data-metric-card="h-index">
            <span class="stat-value" id="stat-h-index">
              {fallback.hIndex}
            </span>
            <span class="stat-label">h-index</span>
          </div>

          <div class="stat-card">
            <span class="stat-value">{fallback.publications}</span>
            <span class="stat-label">Publications</span>
          </div>
        </div>

        <!-- Last-updated line -->
        <p
          class="font-mono text-[10px] tracking-wide mb-8 metrics-updated"
          id="metrics-updated"
          aria-live="polite"
        ></p>

        <!-- CTAs -->
        <div
          class="flex flex-wrap gap-3 mb-8"
          style="animation: fadeInUp 0.65s ease 0.55s both"
        >
          <a href="#publications" class="btn-primary">
            View My Work
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#contact" class="btn-secondary">Get in Touch</a>
        </div>

        <!-- Social links -->
        <div
          class="flex items-center gap-3"
          style="animation: fadeIn 0.6s ease 0.68s both"
        >
          {socials.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="social-link"
            >
              <svg
                viewBox="0 0 24 24"
                width="22"
                height="22"
                fill="currentColor"
                aria-hidden="true"
                set:html={icon}
              />
            </a>
          ))}

          <span class="w-px h-6 bg-[var(--border-subtle)] mx-1" aria-hidden="true"/>

          <a
            href="/cv.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="social-link cv-link"
            aria-label="Download CV"
          >
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
                 stroke="currentColor" stroke-width="1.8"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
            <span class="cv-label">CV</span>
          </a>
        </div>
      </div>
    </div>
  </div>

</section>

<div id="hero-config" data-metrics-url={metricsApiUrl} hidden aria-hidden="true"></div>

<script>
  function timeAgo(isoString: string): string | null {
    const epoch = Date.parse(isoString);
    if (!epoch || epoch === 0) return null;

    const diffMs  = Date.now() - epoch;
    const diffMin = Math.floor(diffMs / 60_000);
    const diffHr  = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHr  / 24);

    if (diffMin <  1)   return 'just now';
    if (diffMin < 60)   return `${diffMin} minute${diffMin === 1 ? '' : 's'} ago`;
    if (diffHr  < 24)   return `${diffHr} hour${diffHr === 1 ? '' : 's'} ago`;
    return `${diffDay} day${diffDay === 1 ? '' : 's'} ago`;
  }

  function updateStat(id: string, newValue: number | null): void {
    const el = document.getElementById(id);
    if (!el || newValue == null) return;
    const display = String(newValue);
    if (el.textContent?.trim() === display) return;

    el.style.transition = 'opacity 0.25s ease';
    el.style.opacity    = '0';
    setTimeout(() => {
      el.textContent   = display;
      el.style.opacity = '1';
    }, 260);
  }

  function setLoadingState(loading: boolean): void {
    document.querySelectorAll('[data-metric-card]').forEach(card => {
      card.classList.toggle('stat-card--loading', loading);
    });
  }

  async function loadMetrics(): Promise<void> {
    const metricsApiUrl = (document.getElementById('hero-config') as HTMLElement | null)
      ?.dataset.metricsUrl ?? '';

    if (!metricsApiUrl) return;

    setLoadingState(true);

    try {
      const res = await fetch(`${metricsApiUrl}/api/metrics`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json() as {
        scholar?:    { citations?: number | null; h_index?: number | null };
        updated_at?: string;
      };

      if (data.scholar) {
        updateStat('stat-scholar-citations', data.scholar.citations ?? null);
        updateStat('stat-h-index',           data.scholar.h_index   ?? null);
      }

      const ago = data.updated_at ? timeAgo(data.updated_at) : null;
      const updatedEl = document.getElementById('metrics-updated');
      if (updatedEl && ago) {
        updatedEl.textContent = `↻ metrics updated ${ago}`;
        updatedEl.classList.add('metrics-updated--visible');
      }
    } catch {
      /* Silently keep fallback values */
    } finally {
      setLoadingState(false);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadMetrics);
  } else {
    loadMetrics();
  }
</script>

<style>
  /* ── Photo ──────────────────────────────────────────────────────────────── */
  .hero-photo-wrap {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 4px 24px rgba(28, 25, 23, 0.1),
      0 1px 4px rgba(28, 25, 23, 0.06);
    background: #e4e1db;
    flex-shrink: 0;
  }

  .hero-photo {
    display: block;
    width: 240px;
    height: 240px;
    object-fit: cover;
    border-radius: inherit;
  }

  @media (min-width: 768px) {
    .hero-photo { width: 260px; height: 260px; }
  }

  @media (min-width: 1024px) {
    .hero-photo { width: 280px; height: 280px; }
  }

  /* ── Social link ────────────────────────────────────────────────────────── */
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 0.5rem;
    color: #a8a29e;
    border: 1px solid var(--border-subtle);
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .social-link:hover {
    color: #0d9488;
    border-color: rgba(13, 148, 136, 0.3);
    background-color: rgba(13, 148, 136, 0.06);
  }

  .cv-link {
    width: auto;
    padding: 0 0.75rem;
    gap: 0.35rem;
  }

  .cv-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  /* ── Stat sub-label ─────────────────────────────────────────────────────── */
  .stat-source {
    display: block;
    font-size: 0.65em;
    opacity: 0.7;
    margin-top: 0.05em;
  }

  /* ── Loading shimmer ────────────────────────────────────────────────────── */
  .stat-card--loading .stat-value {
    position: relative;
    color: transparent;
    border-radius: 0.2rem;
    overflow: hidden;
  }
  .stat-card--loading .stat-value::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(28,25,23,0.04) 0%,
      rgba(28,25,23,0.1) 50%,
      rgba(28,25,23,0.04) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.2s ease-in-out infinite;
    border-radius: inherit;
  }
  @keyframes shimmer {
    0%   { background-position:  200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Last-updated timestamp ─────────────────────────────────────────────── */
  .metrics-updated {
    color: transparent;
    min-height: 1em;
  }
  .metrics-updated--visible {
    color: #c4bfba;
    transition: color 0.4s ease;
  }
</style>
