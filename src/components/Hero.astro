---
import { Image } from 'astro:assets';
import photo    from '../assets/photo.png';

/**
 * Hardcoded fallback values — shown immediately (no layout shift).
 * The client-side script below overwrites them with live data from
 * the citation-metrics Worker once the page loads.
 */
const fallback = {
  scholarCitations: '197',
  hIndex:           '8',
  publications:     '19',
};

const socials = [
  {
    href:  'https://github.com/batuhanhangun',
    label: 'GitHub',
    icon:  `<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482
             0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463
             -.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832
             .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683
             -.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004
             1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647
             .64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852
             0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12
             c0-5.523-4.477-10-10-10z"/>`,
  },
  {
    href:  'https://linkedin.com/in/bhangun',
    label: 'LinkedIn',
    icon:  `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136
             1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85
             3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065
             2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771
             C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227
             24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    href:  'https://scholar.google.com/citations?hl=en&user=kW1pVNEAAAAJ',
    label: 'Google Scholar',
    icon:  `<path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10
             a8 8 0 0 1 7.162 3.44L24 9.5z"/>`,
  },
];

const interests = [
  'Quantum Machine Learning',
  'Machine Learning',
  'High-Performance Computing',
  'Parallel Computing',
  'Computer Vision',
  'Image Processing',
];

const metricsApiUrl = import.meta.env.PUBLIC_METRICS_API_URL ?? '';
---

<section class="min-h-[92vh] flex items-center border-b border-[var(--border-subtle)]">
  <div class="max-w-6xl mx-auto px-6 py-24 w-full">
    <div class="hero-grid">

      <!-- ── Left: photo + social icons ──────────────────────────────────── -->
      <div class="hero-left" style="animation: fadeIn 0.7s ease 0.2s both">
        <div class="hero-photo-wrap">
          <Image
            src={photo}
            alt="Batuhan Hangün"
            width={220}
            height={220}
            quality={90}
            class="hero-photo"
            loading="eager"
          />
        </div>

        <div class="hero-socials">
          {socials.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="social-link"
            >
              <svg
                viewBox="0 0 24 24"
                width="20"
                height="20"
                fill="currentColor"
                aria-hidden="true"
                set:html={icon}
              />
            </a>
          ))}
        </div>
      </div>

      <!-- ── Right: text content ──────────────────────────────────────────── -->
      <div class="hero-right">

        <!-- 1. Eyebrow -->
        <p class="hero-eyebrow" style="animation: fadeIn 0.6s ease 0.1s both">
          PhD Candidate · Yıldız Technical University
        </p>

        <!-- 2. Name -->
        <h1 class="hero-name" style="animation: fadeInUp 0.65s ease 0.2s both">
          Batuhan Hangün
        </h1>

        <!-- 3. Title -->
        <p class="hero-title" style="animation: fadeInUp 0.65s ease 0.3s both">
          Quantum Machine Learning Researcher
        </p>

        <!-- 4. About paragraphs -->
        <div class="hero-bio" style="animation: fadeInUp 0.65s ease 0.35s both">
          <p>
            I am a researcher and engineer working at the intersection of quantum
            computing, machine learning, and high-performance computing. Currently
            pursuing my PhD in Computer Engineering at Yıldız Technical University,
            my research focuses on developing hybrid classical-quantum neural network
            architectures for renewable energy and smart grid applications.
          </p>
          <p>
            Beyond academia, I bring hands-on industry experience in computer vision
            systems, 3D scanning SDK development in C++, and digital twin research
            through international collaborations spanning Turkey, Germany, and Canada.
            I have also taught parallel computing and AI/ML courses across multiple
            universities.
          </p>
          <p>
            My work has been recognised with a competitive <strong>NERSC</strong>{' '}
            Director&apos;s Discretionary Reserve allocation on the{' '}
            <strong>Perlmutter supercomputer</strong> at{' '}
            <strong>Lawrence Berkeley National Laboratory</strong>{' '}
            (<strong>U.S. Department of Energy</strong>), where I run quantum machine
            learning experiments at scale. I serve as a peer reviewer for{' '}
            <strong>16+ international journals</strong> and conferences, including{' '}
            <em>Information Fusion</em>, <em>Engineering Applications of AI</em>,{' '}
            <em>Energy</em>, and <em>IEEE Robotics and Automation Letters</em>.
          </p>
        </div>

        <!-- 5. Research interest tags -->
        <div class="hero-interests" style="animation: fadeInUp 0.65s ease 0.4s both">
          {interests.map(tag => (
            <span class="interest-tag">{tag}</span>
          ))}
        </div>

        <!-- 6. Scholar metrics inline -->
        <div class="hero-metrics" style="animation: fadeInUp 0.65s ease 0.47s both">
          <span class="metric-item" data-metric-card="scholar-citations">
            <span class="stat-value" id="stat-scholar-citations">{fallback.scholarCitations}</span>
            <span class="metric-label">citations</span>
          </span>
          <span class="metric-sep" aria-hidden="true">|</span>
          <span class="metric-item" data-metric-card="h-index">
            <span class="stat-value" id="stat-h-index">{fallback.hIndex}</span>
            <span class="metric-label">h-index</span>
          </span>
          <span class="metric-sep" aria-hidden="true">|</span>
          <span class="metric-item">
            <span class="stat-value">{fallback.publications}</span>
            <span class="metric-label">publications</span>
          </span>
        </div>
        <p
          class="font-mono text-[10px] tracking-wide mb-6 metrics-updated"
          id="metrics-updated"
          aria-live="polite"
        ></p>

        <!-- 7. CTA buttons -->
        <div class="hero-ctas" style="animation: fadeInUp 0.65s ease 0.55s both">
          <a href="/cv.pdf" target="_blank" rel="noopener noreferrer" class="btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
            CV
          </a>
          <a href="#contact" class="btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <polyline points="2 4 12 13 22 4"/>
            </svg>
            Get in Touch
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<div id="hero-config" data-metrics-url={metricsApiUrl} hidden aria-hidden="true"></div>

<script>
  function timeAgo(isoString: string): string | null {
    const epoch = Date.parse(isoString);
    if (!epoch || epoch === 0) return null;

    const diffMs  = Date.now() - epoch;
    const diffMin = Math.floor(diffMs / 60_000);
    const diffHr  = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHr  / 24);

    if (diffMin <  1)   return 'just now';
    if (diffMin < 60)   return `${diffMin} minute${diffMin === 1 ? '' : 's'} ago`;
    if (diffHr  < 24)   return `${diffHr} hour${diffHr === 1 ? '' : 's'} ago`;
    return `${diffDay} day${diffDay === 1 ? '' : 's'} ago`;
  }

  function updateStat(id: string, newValue: number | null): void {
    const el = document.getElementById(id);
    if (!el || newValue == null) return;
    const display = String(newValue);
    if (el.textContent?.trim() === display) return;

    el.style.transition = 'opacity 0.25s ease';
    el.style.opacity    = '0';
    setTimeout(() => {
      el.textContent   = display;
      el.style.opacity = '1';
    }, 260);
  }

  function setLoadingState(loading: boolean): void {
    document.querySelectorAll('[data-metric-card]').forEach(card => {
      card.classList.toggle('stat-card--loading', loading);
    });
  }

  async function loadMetrics(): Promise<void> {
    const metricsApiUrl = (document.getElementById('hero-config') as HTMLElement | null)
      ?.dataset.metricsUrl ?? '';

    if (!metricsApiUrl) return;

    setLoadingState(true);

    try {
      const res = await fetch(`${metricsApiUrl}/api/metrics`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json() as {
        scholar?:    { citations?: number | null; h_index?: number | null };
        updated_at?: string;
      };

      if (data.scholar) {
        updateStat('stat-scholar-citations', data.scholar.citations ?? null);
        updateStat('stat-h-index',           data.scholar.h_index   ?? null);
      }

      const ago = data.updated_at ? timeAgo(data.updated_at) : null;
      const updatedEl = document.getElementById('metrics-updated');
      if (updatedEl && ago) {
        updatedEl.textContent = `↻ metrics updated ${ago}`;
        updatedEl.classList.add('metrics-updated--visible');
      }
    } catch {
      /* Silently keep fallback values */
    } finally {
      setLoadingState(false);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadMetrics);
  } else {
    loadMetrics();
  }
</script>

<style>
  /* ── Two-column grid ─────────────────────────────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 220px 1fr;
      gap: 3.5rem;
      align-items: start;
    }
  }

  /* ── Left column ─────────────────────────────────────────────────────────── */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  @media (min-width: 1024px) {
    .hero-left {
      align-items: flex-start;
      position: sticky;
      top: 5rem;
    }
  }

  /* ── Photo ──────────────────────────────────────────────────────────────── */
  .hero-photo-wrap {
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.10), 0 1px 4px rgba(28, 25, 23, 0.06);
    background: var(--c-surface);
    flex-shrink: 0;
  }

  html.dark .hero-photo-wrap {
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.45), 0 1px 4px rgba(0, 0, 0, 0.3);
    border: 2px solid rgba(255, 255, 255, 0.09);
  }

  .hero-photo {
    display: block;
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: inherit;
  }

  @media (min-width: 1024px) {
    .hero-photo {
      width: 220px;
      height: 220px;
    }
  }

  /* ── Social icons row ───────────────────────────────────────────────────── */
  .hero-socials {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.5rem;
    color: var(--c-muted);
    border: 1px solid var(--border-subtle);
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .social-link:hover {
    color: var(--c-teal);
    border-color: var(--c-border-teal-h);
    background-color: var(--c-teal-bg);
  }

  /* ── Right column ────────────────────────────────────────────────────────── */
  .hero-right {
    display: flex;
    flex-direction: column;
  }

  /* ── 1. Eyebrow ─────────────────────────────────────────────────────────── */
  .hero-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--c-muted);
    margin-bottom: 0.6rem;
  }

  /* ── 2. Name ────────────────────────────────────────────────────────────── */
  .hero-name {
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(2.4rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--c-head);
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  /* ── 3. Title ───────────────────────────────────────────────────────────── */
  .hero-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--c-teal);
    margin-bottom: 1.25rem;
  }

  /* ── 4. Bio ─────────────────────────────────────────────────────────────── */
  .hero-bio {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--c-body);
    margin-bottom: 1.25rem;
  }

  .hero-bio p {
    margin: 0;
    text-align: justify;
    hyphens: auto;
  }

  .hero-bio strong {
    color: var(--c-head);
    font-weight: 600;
  }

  .hero-bio em {
    font-style: italic;
    color: var(--c-head);
  }

  /* ── 5. Interest tags ───────────────────────────────────────────────────── */
  .hero-interests {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }

  .interest-tag {
    font-size: 0.7rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--c-muted);
    background: var(--c-card);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    white-space: nowrap;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .interest-tag:hover {
    color: var(--c-teal);
    border-color: var(--c-border-teal-h);
  }

  /* ── 6. Metrics inline ──────────────────────────────────────────────────── */
  .hero-metrics {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.25rem;
    flex-wrap: wrap;
  }

  .metric-item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-head);
    font-variant-numeric: tabular-nums;
  }

  .metric-label {
    font-size: 0.78rem;
    color: var(--c-muted);
  }

  .metric-sep {
    color: var(--border-subtle);
    font-size: 0.85rem;
    user-select: none;
  }

  /* ── 7. CTAs ────────────────────────────────────────────────────────────── */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* ── Last-updated timestamp ─────────────────────────────────────────────── */
  .metrics-updated {
    color: transparent;
    min-height: 1em;
  }
  .metrics-updated--visible {
    color: var(--c-faint);
    transition: color 0.4s ease;
  }

  /* ── Loading shimmer ────────────────────────────────────────────────────── */
  .stat-card--loading .stat-value {
    position: relative;
    color: transparent;
    border-radius: 0.2rem;
    overflow: hidden;
  }
  .stat-card--loading .stat-value::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--c-shimmer-start) 0%,
      var(--c-shimmer-mid)   50%,
      var(--c-shimmer-start) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.2s ease-in-out infinite;
    border-radius: inherit;
  }
  @keyframes shimmer {
    0%   { background-position:  200% 0; }
    100% { background-position: -200% 0; }
  }
</style>
