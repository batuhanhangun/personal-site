---
import { Image } from 'astro:assets';
import photo    from '../assets/photo.jpg';

/**
 * Hardcoded fallback values — shown immediately (no layout shift).
 * The client-side script below overwrites them with live data from
 * the citation-metrics Worker once the page loads.
 */
const fallback = {
  scholarCitations: '197',
  hIndex:           '8',
  scopusCitations:  '—',
  publications:     '19',
};

const socials = [
  {
    href:  'https://github.com/batuhanhangun',
    label: 'GitHub',
    icon:  `<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482
             0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463
             -.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832
             .092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683
             -.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004
             1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647
             .64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852
             0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12
             c0-5.523-4.477-10-10-10z"/>`,
  },
  {
    href:  'https://linkedin.com/in/bhangun',
    label: 'LinkedIn',
    icon:  `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136
             1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85
             3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065
             2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771
             C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227
             24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>`,
  },
  {
    href:  'https://scholar.google.com/citations?hl=en&user=kW1pVNEAAAAJ',
    label: 'Google Scholar',
    icon:  `<path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10
             a8 8 0 0 1 7.162 3.44L24 9.5z"/>`,
  },
];

/**
 * PUBLIC_METRICS_API_URL — set this in:
 *   .env                  → LOCAL dev  (PUBLIC_METRICS_API_URL=http://localhost:8787)
 *   Cloudflare Pages env  → production (PUBLIC_METRICS_API_URL=https://citation-metrics.<account>.workers.dev)
 *
 * Leave unset to always use fallback values.
 */
const metricsApiUrl = import.meta.env.PUBLIC_METRICS_API_URL ?? '';
---

<section class="relative min-h-[92vh] flex items-center overflow-hidden">

  <!-- ── Circuit trace decorations ──────────────────────────────────────── -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">

    <!-- Bottom-left traces -->
    <svg class="absolute bottom-0 left-0 w-80 h-48 opacity-[0.18]"
         viewBox="0 0 320 192" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path class="trace" d="M 0,160 H 60 V 120 H 140 V 70 H 240 V 30 H 310"
            stroke="#00d4ff" stroke-width="1"/>
      <path class="trace trace-delay-1" d="M 0,192 H 100 V 140 H 180 V 90 H 280"
            stroke="#00d4ff" stroke-width="0.75" stroke-dasharray="4 6"/>
      <circle cx="60"  cy="160" r="2.5" fill="#00d4ff" class="trace-dot td-1"/>
      <circle cx="140" cy="120" r="2.5" fill="#00d4ff" class="trace-dot td-2"/>
      <circle cx="240" cy="70"  r="2.5" fill="#00d4ff" class="trace-dot td-3"/>
    </svg>

    <!-- Top-right traces -->
    <svg class="absolute top-16 right-0 w-64 h-36 opacity-[0.14]"
         viewBox="0 0 256 144" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path class="trace trace-delay-2" d="M 256,30 H 200 V 80 H 120 V 120 H 40"
            stroke="#a855f7" stroke-width="1"/>
      <circle cx="200" cy="30"  r="2" fill="#a855f7" class="trace-dot td-4"/>
      <circle cx="120" cy="80"  r="2" fill="#a855f7" class="trace-dot td-5"/>
    </svg>
  </div>

  <!-- ── Main content grid ───────────────────────────────────────────────── -->
  <div class="max-w-6xl mx-auto px-6 py-28 w-full">
    <div class="grid lg:grid-cols-[1fr_400px] gap-12 xl:gap-20 items-center">

      <!-- ── Left: text ───────────────────────────────────────────────── -->
      <div class="order-2 lg:order-1">
        <!-- Eyebrow badge -->
        <p
          class="font-mono text-cyan text-xs tracking-[0.22em] uppercase mb-7"
          style="animation: fadeIn 0.6s ease 0.05s both"
        >
          PhD Candidate · Quantum ML · HPC &amp; AI
        </p>

        <!-- Name -->
        <h1
          class="text-5xl md:text-6xl xl:text-[4.5rem] font-semibold text-heading leading-[1.07] mb-5"
          style="animation: fadeInUp 0.65s ease 0.15s both"
        >
          Batuhan<br />Hangün
        </h1>

        <!-- Tagline -->
        <p
          class="text-xl md:text-2xl font-light mb-2"
          style="color:#00d4ff; animation: fadeInUp 0.65s ease 0.25s both"
        >
          Quantum Machine Learning Researcher
        </p>
        <p
          class="text-dim text-sm md:text-base mb-10 font-mono"
          style="animation: fadeInUp 0.65s ease 0.32s both"
        >
          HPC &amp; AI Engineer · PhD Candidate at Yıldız Technical University
        </p>

        <!-- ── Stats row ───────────────────────────────────────────────── -->
        <div
          class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-2 max-w-lg"
          style="animation: fadeInUp 0.65s ease 0.42s both"
          id="stats-grid"
        >
          <!-- Scholar Citations — dynamic -->
          <div class="stat-card" data-metric-card="scholar-citations">
            <span class="stat-value" id="stat-scholar-citations">
              {fallback.scholarCitations}
            </span>
            <span class="stat-label">
              Scholar
              <span class="stat-source">Citations</span>
            </span>
          </div>

          <!-- Scopus Citations — dynamic; shows "—" until loaded -->
          <div class="stat-card" data-metric-card="scopus-citations">
            <span class="stat-value" id="stat-scopus-citations">
              {fallback.scopusCitations}
            </span>
            <span class="stat-label">
              Scopus
              <span class="stat-source">Citations</span>
            </span>
          </div>

          <!-- h-index — dynamic -->
          <div class="stat-card" data-metric-card="h-index">
            <span class="stat-value" id="stat-h-index">
              {fallback.hIndex}
            </span>
            <span class="stat-label">h-index</span>
          </div>

          <!-- Publications — static -->
          <div class="stat-card">
            <span class="stat-value">{fallback.publications}</span>
            <span class="stat-label">Publications</span>
          </div>
        </div>

        <!-- Last-updated line — hidden until data loads -->
        <p
          class="font-mono text-[10px] tracking-wide mb-10 metrics-updated"
          id="metrics-updated"
          aria-live="polite"
        ></p>

        <!-- CTAs -->
        <div
          class="flex flex-wrap gap-4 mb-10"
          style="animation: fadeInUp 0.65s ease 0.52s both"
        >
          <a href="#publications" class="btn-primary">
            View My Work
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#contact" class="btn-secondary">Get in Touch</a>
        </div>

        <!-- Social links -->
        <div
          class="flex items-center gap-4"
          style="animation: fadeIn 0.6s ease 0.65s both"
        >
          {socials.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="social-link"
            >
              <svg
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                aria-hidden="true"
                set:html={icon}
              />
            </a>
          ))}

          <span class="w-px h-5 bg-[var(--border-subtle)] mx-1" aria-hidden="true"/>

          <a
            href="/cv.pdf"
            target="_blank"
            rel="noopener noreferrer"
            download
            class="font-mono text-xs text-muted hover:text-cyan transition-colors tracking-wide"
          >
            CV.pdf ↗
          </a>
        </div>
      </div>

      <!-- ── Right: photo + orbital background ───────────────────────── -->
      <div
        class="order-1 lg:order-2 flex items-center justify-center lg:justify-end"
        style="animation: fadeIn 0.8s ease 0.4s both"
      >
        <div class="hero-photo-container">
          <!-- Quantum orbital — subtle background layer behind photo -->
          <svg
            class="hero-orbital-bg"
            viewBox="0 0 340 340"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <defs>
              <filter id="node-glow" x="-120%" y="-120%" width="340%" height="340%">
                <feGaussianBlur stdDeviation="3" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <path id="o1" d="M 30,170 a 140,50 0 1,0 280,0 a 140,50 0 1,0 -280,0"/>
              <path id="o2" d="M 42,170 a 128,45 0 1,0 256,0 a 128,45 0 1,0 -256,0"
                    transform="rotate(55,170,170)"/>
              <path id="o3" d="M 62,170 a 108,38 0 1,0 216,0 a 108,38 0 1,0 -216,0"
                    transform="rotate(-40,170,170)"/>
            </defs>
            <use href="#o1" fill="none" stroke="rgba(0,212,255,0.18)" stroke-width="0.8"/>
            <use href="#o2" fill="none" stroke="rgba(0,212,255,0.12)" stroke-width="0.8"/>
            <use href="#o3" fill="none" stroke="rgba(168,85,247,0.18)" stroke-width="0.8"
                 stroke-dasharray="4 7"/>
            <circle r="3" fill="#00d4ff" filter="url(#node-glow)" opacity="0.7">
              <animateMotion dur="7s" repeatCount="indefinite" calcMode="linear">
                <mpath href="#o1"/>
              </animateMotion>
            </circle>
            <circle r="2.5" fill="#00d4ff" opacity="0.45" filter="url(#node-glow)">
              <animateMotion dur="11s" repeatCount="indefinite" begin="-4s" calcMode="linear">
                <mpath href="#o2"/>
              </animateMotion>
            </circle>
            <circle r="2.5" fill="#a855f7" opacity="0.55" filter="url(#node-glow)">
              <animateMotion dur="9s" repeatCount="indefinite" begin="-2s" calcMode="linear">
                <mpath href="#o3"/>
              </animateMotion>
            </circle>
          </svg>

          <!-- Photo on top -->
          <div class="hero-photo-ring">
            <Image
              src={photo}
              alt="Batuhan Hangün"
              width={280}
              height={280}
              class="hero-photo"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Scroll hint ─────────────────────────────────────────────────────── -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 scroll-hint"
    style="animation: fadeIn 0.6s ease 1.1s both, scrollBounce 1.8s ease-in-out 1.7s infinite"
  >
    <span class="font-mono text-muted text-[10px] tracking-[0.18em] uppercase">Scroll</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
         stroke="rgba(0,212,255,0.45)" stroke-width="2" stroke-linecap="round"
         aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>

</section>

<!--
  Metrics endpoint URL stored in a data attribute so the bundled script
  can read it without needing a define:vars inline script.
  An empty string disables the live fetch and keeps fallback values.
-->
<div id="hero-config" data-metrics-url={metricsApiUrl} hidden aria-hidden="true"></div>

<script>
  /* ── Helpers ────────────────────────────────────────────────────────────── */

  /** Format an ISO timestamp as "X hours ago" / "X minutes ago" / etc. */
  function timeAgo(isoString: string): string | null {
    const epoch = Date.parse(isoString);
    if (!epoch || epoch === 0) return null; // epoch 0 = static fallback sentinel

    const diffMs  = Date.now() - epoch;
    const diffMin = Math.floor(diffMs / 60_000);
    const diffHr  = Math.floor(diffMin / 60);
    const diffDay = Math.floor(diffHr  / 24);

    if (diffMin <  1)   return 'just now';
    if (diffMin < 60)   return `${diffMin} minute${diffMin === 1 ? '' : 's'} ago`;
    if (diffHr  < 24)   return `${diffHr} hour${diffHr === 1 ? '' : 's'} ago`;
    return `${diffDay} day${diffDay === 1 ? '' : 's'} ago`;
  }

  /** Swap a stat value with a quick fade transition. */
  function updateStat(id: string, newValue: number | null): void {
    const el = document.getElementById(id);
    if (!el || newValue == null) return;
    const display = String(newValue);
    if (el.textContent?.trim() === display) return; // already current

    el.style.transition = 'opacity 0.25s ease';
    el.style.opacity    = '0';
    setTimeout(() => {
      el.textContent   = display;
      el.style.opacity = '1';
    }, 260);
  }

  /** Show a loading shimmer on dynamic stat cards while the fetch is in-flight. */
  function setLoadingState(loading: boolean): void {
    document.querySelectorAll('[data-metric-card]').forEach(card => {
      card.classList.toggle('stat-card--loading', loading);
    });
  }

  /* ── Main fetch ─────────────────────────────────────────────────────────── */

  async function loadMetrics(): Promise<void> {
    const metricsApiUrl = (document.getElementById('hero-config') as HTMLElement | null)
      ?.dataset.metricsUrl ?? '';

    if (!metricsApiUrl) return; // endpoint not configured — keep fallback values

    setLoadingState(true);

    try {
      const res = await fetch(`${metricsApiUrl}/api/metrics`);
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const data = await res.json() as {
        scholar?:    { citations?: number | null; h_index?: number | null };
        scopus?:     { citations?: number | null };
        updated_at?: string;
      };

      if (data.scholar) {
        updateStat('stat-scholar-citations', data.scholar.citations ?? null);
        updateStat('stat-h-index',           data.scholar.h_index   ?? null);
      }

      if (data.scopus?.citations != null) {
        updateStat('stat-scopus-citations', data.scopus.citations);
      }

      const ago = data.updated_at ? timeAgo(data.updated_at) : null;
      const updatedEl = document.getElementById('metrics-updated');
      if (updatedEl && ago) {
        updatedEl.textContent = `↻ metrics updated ${ago}`;
        updatedEl.classList.add('metrics-updated--visible');
      }
    } catch {
      /* Silently keep fallback values — no error state shown to users */
    } finally {
      setLoadingState(false);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', loadMetrics);
  } else {
    loadMetrics();
  }
</script>

<style>
  /* ── Social link pill ───────────────────────────────────────────────────── */
  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    color: #52526a;
    border: 1px solid var(--border-subtle);
    transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
  }
  .social-link:hover {
    color: #00d4ff;
    border-color: rgba(0, 212, 255, 0.25);
    background-color: rgba(0, 212, 255, 0.06);
  }

  /* ── Stat source sub-label ──────────────────────────────────────────────── */
  .stat-source {
    display: block;
    font-size: 0.65em;
    opacity: 0.7;
    margin-top: 0.05em;
  }

  /* ── Loading shimmer on dynamic stat cards ──────────────────────────────── */
  .stat-card--loading .stat-value {
    position: relative;
    color: transparent;
    border-radius: 0.2rem;
    overflow: hidden;
  }
  .stat-card--loading .stat-value::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(255,255,255,0.04) 0%,
      rgba(255,255,255,0.10) 50%,
      rgba(255,255,255,0.04) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.2s ease-in-out infinite;
    border-radius: inherit;
  }
  @keyframes shimmer {
    0%   { background-position:  200% 0; }
    100% { background-position: -200% 0; }
  }

  /* ── Last-updated timestamp ─────────────────────────────────────────────── */
  .metrics-updated {
    color: transparent;
    /* takes up space so the layout doesn't jump */
    min-height: 1em;
  }
  .metrics-updated--visible {
    color: #3a3a52;
    transition: color 0.4s ease;
  }

  /* ── Circuit trace draw-on animation ───────────────────────────────────── */
  .trace {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: drawTrace 2s ease 0.6s forwards;
  }
  .trace-delay-1 {
    animation-delay: 0.9s;
    animation-duration: 2.2s;
  }
  .trace-delay-2 {
    animation-delay: 0.75s;
    animation-duration: 1.8s;
  }

  .trace-dot { opacity: 0; }
  .td-1 { animation: dotAppear 0.01s ease 1.1s forwards; }
  .td-2 { animation: dotAppear 0.01s ease 1.4s forwards; }
  .td-3 { animation: dotAppear 0.01s ease 1.7s forwards; }
  .td-4 { animation: dotAppear 0.01s ease 1.2s forwards; }
  .td-5 { animation: dotAppear 0.01s ease 1.5s forwards; }

  @keyframes drawTrace  { to { stroke-dashoffset: 0; } }
  @keyframes dotAppear  { to { opacity: 1; } }

  /* ── Profile photo ──────────────────────────────────────────────────────── */
  .hero-photo-container {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    /* sized to the orbital SVG so it doesn't overflow the column */
    width: 240px;
    height: 240px;
  }

  @media (min-width: 768px) {
    .hero-photo-container { width: 300px; height: 300px; }
  }

  @media (min-width: 1024px) {
    .hero-photo-container { width: 340px; height: 340px; }
  }

  .hero-orbital-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .hero-photo-ring {
    position: relative;
    z-index: 1;
    border-radius: 50%;
    padding: 3px;
    background: linear-gradient(
      135deg,
      rgba(0, 212, 255, 0.55) 0%,
      rgba(168, 85, 247, 0.25) 60%,
      rgba(0, 212, 255, 0.15) 100%
    );
    box-shadow:
      0 0 28px rgba(0, 212, 255, 0.18),
      0 0 64px rgba(0, 212, 255, 0.07);
  }

  .hero-photo {
    display: block;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    box-shadow: inset 0 0 0 2px rgba(10, 10, 20, 0.6);
  }

  @media (min-width: 768px) {
    .hero-photo { width: 240px; height: 240px; }
  }

  @media (min-width: 1024px) {
    .hero-photo { width: 280px; height: 280px; }
  }
</style>
