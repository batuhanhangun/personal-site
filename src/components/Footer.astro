---
const year = new Date().getFullYear();

const socials = [
  {
    href:  'https://github.com/batuhanhangun',
    label: 'GitHub',
    icon: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>`,
  },
  {
    href:  'https://www.linkedin.com/in/bhangun',
    label: 'LinkedIn',
    icon: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`,
  },
  {
    href:  'https://scholar.google.com/citations?hl=en&user=kW1pVNEAAAAJ',
    label: 'Google Scholar',
    icon: `<path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 10a8 8 0 0 1 7.162 3.44L24 9.5z"/>`,
  },
];
---

<footer class="site-footer">
  <div class="footer-inner">

    <!-- Logo + tagline -->
    <div class="footer-brand">
      <span class="footer-logo">BH</span>
      <span class="footer-tagline">Quantum ML &amp; HPC Research</span>
    </div>

    <!-- Social links -->
    <nav class="footer-socials" aria-label="Social links">
      {socials.map(s => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="footer-social-link"
          aria-label={s.label}
        >
          <svg
            viewBox="0 0 24 24"
            width="17" height="17"
            fill={s.label === 'Google Scholar' ? 'currentColor' : 'none'}
            stroke={s.label === 'Google Scholar' ? 'none' : 'currentColor'}
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            set:html={s.icon}
          />
        </a>
      ))}
    </nav>

    <!-- Legal + credit -->
    <div class="footer-legal">
      <span>© {year} Batuhan Hangün. All rights reserved.</span>
      <span class="footer-sep" aria-hidden="true">·</span>
      <span>
        Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-credit-link"
        >Astro</a>
        &amp; deployed on
        <a
          href="https://pages.cloudflare.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-credit-link"
        >Cloudflare Pages</a>
      </span>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-subtle);
    padding: 2.25rem 0 1.75rem;
    background: #e4e1db;
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.125rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: 1rem;
    }
  }

  /* ── Brand ──────────────────────────────────────────────────────────── */
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .footer-logo {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #0d9488;
  }

  .footer-tagline {
    font-size: 0.77rem;
    color: #a8a29e;
    letter-spacing: 0.02em;
  }

  /* ── Social icons ───────────────────────────────────────────────────── */
  .footer-socials {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .footer-social-link {
    color: #a8a29e;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }
  .footer-social-link:hover { color: #57534e; }

  /* ── Legal row ──────────────────────────────────────────────────────── */
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    font-size: 0.73rem;
    color: #a8a29e;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .footer-legal { justify-content: flex-end; }
  }

  .footer-sep {
    color: #c4bfba;
    user-select: none;
  }

  .footer-credit-link {
    color: #a8a29e;
    text-decoration: underline;
    text-decoration-color: rgba(28, 25, 23, 0.12);
    transition: color 0.2s ease;
  }
  .footer-credit-link:hover { color: #57534e; }
</style>
