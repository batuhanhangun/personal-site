---
interface Props {
  /** Mono label shown above the title, e.g. "01 —" */
  label?: string;
  title: string;
  subtitle?: string;
  /** Align text center instead of left */
  centered?: boolean;
}

const { label, title, subtitle, centered = false } = Astro.props;
---

<div class:list={['mb-7', centered && 'text-center']}>
  {label && (
    <p class="font-mono text-cyan text-xs tracking-[0.2em] uppercase mb-3">
      {label}
    </p>
  )}

  <h2 class="font-serif text-3xl md:text-4xl text-heading leading-tight">
    {title}
  </h2>

  {subtitle && (
    <p class:list={['mt-3 text-dim text-base leading-relaxed', !centered && 'max-w-2xl']}>
      {subtitle}
    </p>
  )}

  <!-- Decorative rule -->
  <div
    class:list={[
      'mt-5 h-0.5 w-10 rounded-full bg-cyan opacity-60',
      centered && 'mx-auto',
    ]}
  />
</div>
