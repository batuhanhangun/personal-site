---
import Section from './Section.astro';
import SectionHeading from './SectionHeading.astro';

interface Journal {
  name: string;
}

interface PublisherGroup {
  publisher: string;
  dot: string;
  journals: Journal[];
}

const groups: PublisherGroup[] = [
  {
    publisher: 'Elsevier',
    dot: '#f97316',
    journals: [
      { name: 'Information Fusion'             },
      { name: 'Engineering Applications of AI' },
      { name: 'Energy'                         },
      { name: 'Energy Strategy Reviews'        },
      { name: 'Energy Reports'          },
      { name: 'Journal of Energy Storage'},
      { name: 'Sustainable Cities and Society' },
      { name: 'Ocean Engineering'        },
      { name: 'Heliyon'                  },
      { name: 'Next Energy'              },
      { name: 'Next Research'            },
      { name: 'Unconventional Resources' },
    ],
  },
  {
    publisher: 'IEEE',
    dot: '#0d9488',
    journals: [
      { name: 'Robotics and Automation Letters' },
    ],
  },
  {
    publisher: 'Springer Nature',
    dot: '#22c55e',
    journals: [
      { name: 'SN Computer Science' },
    ],
  },
  {
    publisher: 'Conferences',
    dot: '#a8a29e',
    journals: [
      { name: 'IcSmartGrid' },
      { name: 'ICRERA'      },
      { name: 'AQ-QCAS'    },
    ],
  },
];

const totalJournals = groups.reduce((n, g) => n + g.journals.length, 0);
---

<Section id="peer-review">
  <SectionHeading
    title="Peer Review Service"
    subtitle={`Invited as a recognised expert to review for ${totalJournals} international journals and conferences.`}
  />

  <div class="review-wrap">
    {groups.map(group => (
      <div class="review-group">

        <div class="publisher-col">
          <span
            class="publisher-dot"
            style={`background:${group.dot}`}
            aria-hidden="true"
          />
          <span class="publisher-name">{group.publisher}</span>
          <span class="publisher-count">{group.journals.length}</span>
        </div>

        <ul class="journal-tags" role="list" aria-label={`${group.publisher} journals`}>
          {group.journals.map(j => (
            <li role="listitem">
              <span class="journal-tag">{j.name}</span>
            </li>
          ))}
        </ul>

      </div>
    ))}
  </div>
</Section>

<style>
  /* ── Outer wrapper ────────────────────────────────────────────────── */
  .review-wrap {
    border: 1px solid var(--border-subtle);
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--c-card);
  }

  /* ── Publisher row ────────────────────────────────────────────────── */
  .review-group {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1rem 1.35rem;
    border-bottom: 1px solid var(--border-subtle);
    transition: background 0.15s ease;
  }
  .review-group:last-child { border-bottom: none; }
  .review-group:hover { background: var(--c-inset); }

  @media (min-width: 640px) {
    .review-group {
      flex-direction: row;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }

  /* ── Publisher label column ───────────────────────────────────────── */
  .publisher-col {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-shrink: 0;
    min-width: 9rem;
    padding-top: 0.1rem;
  }

  .publisher-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .publisher-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-body);
    white-space: nowrap;
  }

  .publisher-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--c-muted);
    background: var(--c-count-bg);
    border: 1px solid var(--c-count-border);
    border-radius: 9999px;
    padding: 0.05rem 0.38rem;
    line-height: 1.5;
  }

  /* ── Journal tags ─────────────────────────────────────────────────── */
  .journal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex: 1;
  }

  .journal-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.18rem 0.55rem;
    font-size: 0.74rem;
    border-radius: 9999px;
    border: 1px solid var(--border-subtle);
    color: var(--c-body);
    background: var(--c-inset);
    white-space: nowrap;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .journal-tag:hover {
    border-color: var(--c-border-dark);
    color: var(--c-head);
  }

</style>
