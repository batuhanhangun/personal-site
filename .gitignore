# ── Build output ──────────────────────────────────────────────────────────────
dist/
.astro/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
workers/*/node_modules/

# ── Environment & secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.dev.vars              # wrangler local secrets file
workers/*/.dev.vars

# ── Wrangler runtime artifacts ────────────────────────────────────────────────
.wrangler/
workers/*/.wrangler/

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Claude Code local settings (tool permissions — not project code) ──────────
.claude/

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
